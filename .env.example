# ── Copy this file to .env and fill in your values ───────────────────────────
# Never commit .env to GitHub!

# OpenAI API key (used by LangChain for LLM + embeddings)
OPENAI_API_KEY=sk-...

# Model names (change if you want to use gpt-4o-mini to save cost)
LLM_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# Paths (leave as-is unless you move files)
DB_PATH=data/apple_support.db
CHROMA_DIR=data/chroma_db
PDF_DIR=data/pdfs
